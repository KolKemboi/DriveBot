<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <ros2_control name = "Four_Wheel_Hardware" type = "system">

			<hardware>
				<plugin>four_wheel_hardware/DiffBotSystemHardware</plugin>
				<param name="hw_start_duration_sec">3</param>
				<param name="hw_stop_duration_sec">3</param>

				<param name="serial_port">/dev/ttyACM0</param>
				<param name="baudrate">115200</param>
			</hardware>

        <joint name="front_left_joint">
            <command_interface name = "velocity">
            </command_interface>
            <state_interface name = "position" />
						<state_interface name = "velocity" />

        </joint>

        <joint name="back_left_joint">
            <command_interface name = "velocity">
            </command_interface>
            <state_interface name = "position" />
						<state_interface name = "velocity" />

        </joint>

        <joint name="front_right_joint">
            <command_interface name = "velocity">
            </command_interface>
            <state_interface name = "position" />
						<state_interface name = "velocity" />

        </joint>


        <joint name="back_right_joint">
            <command_interface name = "velocity">
            </command_interface>
            <state_interface name = "position" />
						<state_interface name = "velocity" />

        </joint>


    </ros2_control>

    
</robot>
